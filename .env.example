# Shared configuration for backend + frontend (Docker and local dev)
NODE_ENV=development

# Backend
PORT=5000

# MongoDB
# Docker default: mongodb://mongo:27017/LaConslaNet
# Local default:  mongodb://localhost:27017/LaConslaNet
MONGO_URI=mongodb://mongo:27017/LaConslaNet

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# CORS origins (comma-separated)
FRONTEND_URL=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501

# Frontend runtime config
FRONTEND_PORT=5500
API_BASE_URL=http://localhost:5500

# Optional
MAX_FILE_SIZE=10mb
UPLOAD_PATH=./uploads
