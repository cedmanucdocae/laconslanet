# Backend reads ../.env by default (shared root env).
# This file exists only as a local fallback if root .env is missing.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/LaConslaNet
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
FRONTEND_URL=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501
MAX_FILE_SIZE=10mb
UPLOAD_PATH=./uploads
